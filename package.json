{
  "name": "embedded-queue",
  "version": "0.0.4",
  "description": "Embedded job/message queue",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./client-types": {
      "types": "./dist/esm/client-types.d.ts",
      "import": "./dist/esm/client-types.js",
      "require": "./dist/cjs/client-types.cjs"
    }
  },
  "license": "MIT",
  "keywords": [
    "queue",
    "electron",
    "nedb"
  ],
  "author": {
    "name": "Benjamin Hajnal",
    "email": "hajnalbenjamin@gmail.com"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json; pnpm exec tsc -p tsconfig.cjs.json; node rename-cjs.cjs",
    "build:esm": "pnpm exec tsc -p tsconfig.json",
    "build:cjs": "pnpm exec tsc -p tsconfig.cjs.json; node rename-cjs.cjs",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "async-sema": "^3.1.1",
    "next-tick": "^1.1.0",
    "uuid": "8.x"
  },
  "devDependencies": {
    "@types/jest": "27.x",
    "@types/nedb": "1.8.x",
    "@types/next-tick": "^1.0.2",
    "@types/node": "*",
    "@types/uuid": "8.x",
    "@typescript-eslint/eslint-plugin": "5.x",
    "@typescript-eslint/parser": "5.x",
    "eslint": "8.x",
    "eslint-plugin-jest": "25.x",
    "jest": "27.x",
    "jest-mock-extended": "2.x",
    "nedb": "^1.8.0",
    "ts-jest": "27.x",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hajnalben/embedded-queue.git"
  },
  "bugs": {
    "url": "https://github.com/hajnalben/embedded-queue/issues"
  },
  "homepage": "https://github.com/hajnalben/embedded-queue#readme"
}