{
  "name": "embedded-queue",
  "version": "0.0.4",
  "description": "Embedded job/message queue",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./client-types": {
      "types": "./dist/esm/client-types.d.ts",
      "import": "./dist/esm/client-types.js",
      "require": "./dist/cjs/client-types.cjs"
    }
  },
  "license": "MIT",
  "keywords": [
    "queue",
    "electron",
    "nedb"
  ],
  "author": {
    "name": "Benjamin Hajnal",
    "email": "hajnalbenjamin@gmail.com"
  },
  "scripts": {
    "build": "node run-build.cjs",
    "build:esm": "pnpm exec tsc -p tsconfig.json",
    "build:cjs": "node run-build-cjs.cjs",
    "test": "echo 'tests skipped (vendored dep)'",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "async-sema": "^3.1.1",
    "next-tick": "^1.1.0",
    "uuid": "~8.3.2"
  },
  "devDependencies": {
    "@types/jest": "~27.5.2",
    "@types/nedb": "1.8.16",
    "@types/next-tick": "^1.0.2",
    "@types/node": "^22.20.0",
    "@types/uuid": "~8.3.4",
    "@typescript-eslint/eslint-plugin": "~5.62.0",
    "@typescript-eslint/parser": "~5.62.0",
    "eslint": "~8.57.1",
    "eslint-plugin-jest": "~25.7.0",
    "jest": "~27.5.1",
    "jest-mock-extended": "~2.0.9",
    "nedb": "^1.8.0",
    "ts-jest": "~27.1.5",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hajnalben/embedded-queue.git"
  },
  "bugs": {
    "url": "https://github.com/hajnalben/embedded-queue/issues"
  },
  "homepage": "https://github.com/hajnalben/embedded-queue#readme"
}